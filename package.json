{
  "name": "@vishmindbowser/ui-feedback-plugin",
  "version": "0.1.0",
  "description": "A floating widget for collecting annotated UI feedback on web prototypes — Figma-style comments, screenshots, reply threads, Firebase/Supabase/S3 support",
  "main": "dist/ui-feedback-plugin.umd.js",
  "module": "dist/ui-feedback-plugin.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ui-feedback-plugin.es.js",
      "require": "./dist/ui-feedback-plugin.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "feedback",
    "annotation",
    "ui",
    "prototype",
    "comments",
    "screenshot",
    "firebase",
    "supabase"
  ],
  "author": "Vishvajit Sande",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vishmindbowser/ui-feedback-plugin.git"
  },
  "homepage": "https://github.com/vishmindbowser/ui-feedback-plugin#readme",
  "devDependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "firebase": "^10.12.0",
    "html2canvas": "^1.4.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1"
  }
}
