# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# ── Pick a provider ───────────────────────────────────────────────────────────
# Options: supabase | firebase | aws
VITE_PROVIDER=supabase

VITE_PROJECT_KEY=demo-v1

# ── Supabase ──────────────────────────────────────────────────────────────────
# Run the SQL setup in the README (or src/adapters/supabase.ts) before using.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Firebase ──────────────────────────────────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# ── AWS (Cognito Identity Pool — no backend needed) ───────────────────────────
# The browser gets temporary credentials from Cognito and talks to S3 directly.
# See the README or src/adapters/aws.ts for full AWS setup instructions.
# VITE_AWS_REGION=us-east-1
# VITE_AWS_BUCKET=your-bucket-name
# VITE_AWS_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
