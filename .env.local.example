# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# ── Pick ONE provider ─────────────────────────────────────────────────────────

# Supabase (run the SQL in src/adapters/supabase.ts first)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Firebase (comment out Supabase vars above if using this)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# ── Common ────────────────────────────────────────────────────────────────────
VITE_PROJECT_KEY=demo-v1

# ── S3 screenshots (optional, requires your own backend proxy) ────────────────
# VITE_S3_UPLOAD_ENDPOINT=https://your-api.com/upload-screenshot
