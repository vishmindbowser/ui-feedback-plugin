# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# ── Pick a provider ───────────────────────────────────────────────────────────
# Options: supabase | firebase | s3
VITE_PROVIDER=supabase

VITE_PROJECT_KEY=demo-v1

# ── Supabase ──────────────────────────────────────────────────────────────────
# Run the SQL setup in src/adapters/supabase.ts first.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Firebase ──────────────────────────────────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# ── AWS S3 (via your backend API — AWS credentials stay on your server) ───────
# See src/adapters/s3.ts for the required API contract and Node.js example.
# VITE_S3_API_URL=http://localhost:3001/ufp
# VITE_S3_API_TOKEN=your-internal-api-token
